{
  "name": "@maraaj/api",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/main.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "echo ok",
    "test": "vitest run",
    "test:security": "vitest run src/security",
    "seed": "tsx src/cli/seed.ts",
    "admin:create": "tsx src/cli/admin-create.ts",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@maraaj/auth": "workspace:*",
    "@maraaj/cache": "workspace:*",
    "@maraaj/config": "workspace:*",
    "@maraaj/crypto": "workspace:*",
    "@maraaj/database": "workspace:*",
    "@maraaj/logging": "workspace:*",
    "@maraaj/observability": "workspace:*",
    "@maraaj/queue": "workspace:*",
    "@maraaj/qr": "workspace:*",
    "@maraaj/social-card": "workspace:*",
    "@maraaj/storage": "workspace:*",
    "@maraaj/types": "workspace:*",
    "@maraaj/validation": "workspace:*",
    "@nestjs/common": "^11.1.3",
    "@nestjs/core": "^11.1.3",
    "@nestjs/platform-express": "^11.1.3",
    "@nestjs/swagger": "^11.2.0",
    "bullmq": "^5.56.0",
    "cookie-parser": "^1.4.7",
    "helmet": "^8.1.0",
    "ioredis": "^5.6.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "uuid": "^11.1.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.9",
    "@types/express": "^5.0.3",
    "@types/node": "^22.15.32",
    "@types/supertest": "^6.0.3",
    "supertest": "^7.1.1",
    "tsx": "^4.20.3",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
