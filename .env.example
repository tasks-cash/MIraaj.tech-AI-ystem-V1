# Prompt 5 — creative media generation + rendering
AI_CREATIVE_QUEUE_NAME=miraaj.ai.creative-generation
AI_CREATIVE_DLQ_NAME=miraaj.ai.creative-generation.dead-letter
AI_CREATIVE_WORKER_CONCURRENCY=2
AI_CREATIVE_IMAGE_CONCURRENCY=2
AI_CREATIVE_VIDEO_CONCURRENCY=1
