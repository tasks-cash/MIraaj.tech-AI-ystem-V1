# Browser-safe URLs only. Never add provider credentials to NEXT_PUBLIC_* variables.
NEXT_PUBLIC_SITE_URL=http://localhost:3200
NEXT_PUBLIC_API_URL=http://localhost:4200

APP_ENV=development
LOG_LEVEL=info

API_HOST=0.0.0.0
API_PORT=4200

AI_SERVICE_HOST=127.0.0.1
AI_SERVICE_PORT=8200
AI_SERVICE_ID=miraaj-api
AI_SERVICE_ALLOWED_IDS=miraaj-api
AI_SERVICE_INTERNAL_SECRET=local-development-only-change-this-secret
AI_SERVICE_URL=http://localhost:8200
AI_SERVICE_REQUEST_TIMEOUT_MS=5000
AI_SERVICE_REPLAY_WINDOW_SECONDS=120
AI_SERVICE_REDIS_REQUIRED=false
AI_SERVICE_DEPENDENCY_TIMEOUT_MS=1000
AI_SERVICE_VERSION=0.1.0

# Temporary, controlled administration only. Production startup rejects this mode
# unless ALLOW_TEMPORARY_ADMIN_TOKEN_IN_PRODUCTION is explicitly set to true.
TEMPORARY_ADMIN_TOKEN_ENABLED=true
ALLOW_TEMPORARY_ADMIN_TOKEN_IN_PRODUCTION=false
ADMIN_API_TOKEN=local-development-only-admin-token-change-me

# Prompt 2 — OCR language bundles (install required packs in AI service image).
# Do not install every optional pack into the production image by default.
OCR_LANGUAGES_DEFAULT=ara+eng+fra
OCR_LANGUAGES_INSTALLED=ara,eng,fra,spa,deu,por,ita,nld,tur,rus
OCR_MAX_LANGUAGES_PER_JOB=4
OCR_PRELIMINARY_LANGUAGES=eng
OCR_MIN_CONFIDENCE=0.55
OCR_RETRY_MIN_CONFIDENCE=0.35

# Prompt 2 — media limits (no unlimited values; validated at startup)
MEDIA_MAX_IMAGE_BYTES=15728640
MEDIA_MAX_PDF_BYTES=26214400
MEDIA_MAX_IMAGE_WIDTH=12000
MEDIA_MAX_IMAGE_HEIGHT=12000
MEDIA_MAX_IMAGE_PIXELS=50000000
MEDIA_MAX_PDF_PAGES=25
MEDIA_MAX_TOTAL_RENDERED_PIXELS=150000000
MEDIA_UPLOAD_SESSION_TTL_SECONDS=1800
MEDIA_PROCESSING_TIMEOUT_SECONDS=120
MEDIA_OCR_TIMEOUT_SECONDS=90
MEDIA_VISION_TIMEOUT_SECONDS=90
MEDIA_MAX_RETRIES=3
MEDIA_WORKER_CONCURRENCY=2
MEDIA_NORMALIZED_IMAGE_FORMAT=webp
MEDIA_NORMALIZED_IMAGE_QUALITY=90
MEDIA_PRESIGNED_UPLOAD_TTL_SECONDS=900
MEDIA_PRESIGNED_READ_TTL_SECONDS=120
MEDIA_PERCEPTUAL_HASH_DISTANCE=8
MEDIA_STALE_JOB_HEARTBEAT_SECONDS=180
MEDIA_FETCH_ALLOWED_HOSTS=localhost,127.0.0.1,minio
MEDIA_FETCH_TIMEOUT_SECONDS=30

# Prompt 2 — confidence thresholds
CONFIDENCE_AUTO_COMPLETE_MIN=0.82
CONFIDENCE_REVIEW_MIN=0.50
CONFIDENCE_LOW_BELOW=0.50

# Prompt 2 — BullMQ queue names
BULLMQ_VALIDATE_QUEUE=miraaj.ai.media.validate
BULLMQ_ANALYZE_QUEUE=miraaj.ai.media.analyze
BULLMQ_DEAD_LETTER_QUEUE=miraaj.ai.media.dead-letter

# Prompt 2 — vision provider (Gemini credentials live only in AI service runtime)
VISION_PROVIDER_ENABLED=false
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
GEMINI_TIMEOUT_SECONDS=90
GEMINI_MAX_RETRIES=1
GEMINI_TEMPERATURE=0.1
GEMINI_MAX_OUTPUT_TOKENS=4096

# Prompt 3 — business intelligence + service matching
AI_INTELLIGENCE_QUEUE_NAME=miraaj.ai.intelligence
AI_INTELLIGENCE_DLQ_NAME=miraaj.ai.intelligence.dead-letter
AI_INTELLIGENCE_WORKER_CONCURRENCY=2
AI_INTELLIGENCE_MAX_RETRIES=3
AI_INTELLIGENCE_TIMEOUT_SECONDS=120
AI_INTELLIGENCE_STALE_SECONDS=300
AI_INTELLIGENCE_RECONCILE_INTERVAL_SECONDS=60
AI_REASONING_PROVIDER=disabled
AI_REASONING_MODEL=
AI_REASONING_TIMEOUT_SECONDS=60
AI_REASONING_MAX_RETRIES=2
AI_REASONING_MAX_INPUT_CHARS=30000
SERVICE_MATCH_AUTO_APPROVE_MIN=0.85
SERVICE_MATCH_REVIEW_MIN=0.55
SERVICE_MATCH_PRIMARY_LIMIT=10
SERVICE_MATCH_SUPPORTING_LIMIT=15
SERVICE_MATCH_OPTIONAL_LIMIT=10
SERVICE_MATCH_FUTURE_LIMIT=10
SERVICE_MATCH_DECISION_MAKER_MIN=0.65
SERVICE_MATCH_PROFESSIONAL_CONTEXT_MIN=0.65

# Prompt 4 — campaign intelligence + multilingual package generation
