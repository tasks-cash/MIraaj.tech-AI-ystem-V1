CREATIVE_BRAND_SCORE_MIN=0.85
CREATIVE_COMPLIANCE_SCORE_MIN=0.95
CREATIVE_TEXT_ACCURACY_MIN=0.92
CREATIVE_RIGHTS_CONFIDENCE_MIN=0.90
